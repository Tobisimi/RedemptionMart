# Supabase (create project at https://supabase.com)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Backend
PORT=3001
FRONTEND_URL=http://localhost:5173

# Paystack (server only — set on Vercel dashboard, NOT in frontend VITE_ vars)
PAYSTACK_SECRET_KEY=

# Optional on Vercel (auto-detected from your live URL if omitted)
FRONTEND_URL=

# Frontend (Vite — browser-safe keys only)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Leave empty on Vercel — payments use /api on the same domain
VITE_API_URL=
