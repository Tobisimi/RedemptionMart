# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Paystack — set on Vercel (server env only)
PAYSTACK_SECRET_KEY=

# Frontend (Vite)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Public VAPID key for Web Push (same value as VAPID_PUBLIC_KEY)
VITE_VAPID_PUBLIC_KEY=
# Leave empty on Vercel — payments use /api on same domain
VITE_API_URL=

# Local backend only (optional, for npm run dev)
PORT=3001
FRONTEND_URL=http://localhost:5173

# Push notifications (optional — generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@redemptionmart.local

# Vercel cron protection (set on Vercel; used by hourly auto-cancel job)
CRON_SECRET=

# Paystack webhook URL (set in Paystack dashboard): https://your-domain/api/payments/webhook
