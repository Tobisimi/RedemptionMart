# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Paystack — set on Vercel (server env, not VITE_)
PAYSTACK_SECRET_KEY=

# Frontend (Vite)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Leave empty on Vercel — payments use /api on same domain
VITE_API_URL=

# Local backend only (optional, for npm run dev)
PORT=3001
FRONTEND_URL=http://localhost:5173
