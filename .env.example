# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Backend (local)
PORT=3001
FRONTEND_URL=http://localhost:5173

# Paystack (backend only — never expose secret key in frontend)
PAYSTACK_SECRET_KEY=

# Frontend (Vite)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Render backend URL on production, e.g. https://redemptionmart-api.onrender.com
VITE_API_URL=

# Render backend: set FRONTEND_URL to your Vercel site, e.g. https://redemptionmart.vercel.app
# FRONTEND_URL_PRODUCTION=https://redemptionmart.vercel.app
